{
  "name": "therapy-log",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "generate:migrations": "tsx scripts/generate-migrations.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "prebuild": "npm run generate:migrations",
    "build": "electron-vite build",
    "prepackage": "npm run generate:icons && npm run build",
    "package:win": "npm run prepackage && electron-builder --win",
    "package:mac": "npm run prepackage && electron-builder --mac",
    "package:all": "npm run prepackage && electron-builder -mw",
    "package:dir": "npm run prepackage && electron-builder --dir",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "npm run rebuild:node && (vitest run; npm run rebuild:electron)",
    "test:watch": "npm run rebuild:node && (vitest; npm run rebuild:electron)",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "npm run rebuild:node && (tsx prisma/seed.ts; npm run rebuild:electron)"
  },
  "build": {
    "appId": "com.therapylog.app",
    "productName": "TherapyLog",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.healthcare-fitness"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-window-state": "^5.0.3",
    "lucide-react": "^0.564.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "prisma": "^7.4.0",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
